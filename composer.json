{
    "name": "tcgunel/omniship-dev",
    "description": "Omniship development and testing environment",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "./omniship",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "./omniship-yurtici",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "tcgunel/omniship-common": "@dev",
        "tcgunel/omniship-yurtici": "@dev",
        "nyholm/psr7": "^1.8",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    }
}
